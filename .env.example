# Environment variables — copy this file as .env and fill in the values
# cp .env.example .env

# Secret key for Flask (sessions, CSRF). Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_hex_string

# Cloudflare Tunnel token. Get yours at:
# dash.cloudflare.com → Zero Trust → Networks → Tunnels → your tunnel → Configure → Install connector
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Rate limiting
RATE_LIMIT_PER_HOUR=10
RATE_LIMIT_PER_MINUTE=3

# WebAuthn (Passkey) — admin panel at /db
# RP_ID must be exactly the domain without protocol
# e.g. for https://yt2mp3.example.com use yt2mp3.example.com
WEBAUTHN_RP_ID=yt2mp3.example.com
WEBAUTHN_RP_NAME=yt2mp3 admin
# Full origin with protocol and subdomain
WEBAUTHN_ORIGIN=https://yt2mp3.example.com

# Enable secure cookies (HTTPS). Set to true in production
SESSION_COOKIE_SECURE=true

# Email notifications — sent on every completed download
# Uses Gmail SMTP with an App Password (not your account password)
# To generate an App Password: myaccount.google.com → Security → 2-Step Verification → App passwords
ADMIN_EMAIL=your_email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=your_gmail@gmail.com

# Admin panel auto-refresh interval in seconds (default: 300)
ADMIN_REFRESH_INTERVAL=300

# GeoIP database path (MaxMind GeoLite2-City.mmdb)
# Download free from: https://www.maxmind.com/en/geolite2/signup
# Place the .mmdb file in the ./geoip/ directory (created automatically by docker-compose)
GEOIP_PATH=/app/geoip/GeoLite2-City.mmdb

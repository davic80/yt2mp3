# Variables de entorno — copia este archivo como .env y rellena los valores
# cp .env.example .env

# Clave secreta para Flask (sesiones, CSRF). Genera una con:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_hex_string

# Token del Cloudflare Tunnel. Obtén el tuyo en:
# dash.cloudflare.com → Zero Trust → Networks → Tunnels → tu tunnel → Configure → Install connector
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Rate limiting
RATE_LIMIT_PER_HOUR=10
RATE_LIMIT_PER_MINUTE=3

# WebAuthn (Passkey) — panel de admin en /db
# RP_ID debe ser exactamente el dominio sin subdominio ni protocolo
# Ej: para diana.f1madrid.win usa f1madrid.win (o diana.f1madrid.win si solo va a ese subdominio)
WEBAUTHN_RP_ID=diana.f1madrid.win
WEBAUTHN_RP_NAME=yt2mp3 admin
# Origin completo con protocolo y subdominio
WEBAUTHN_ORIGIN=https://diana.f1madrid.win

# Activar cookies seguras (HTTPS). Poner true en producción
SESSION_COOKIE_SECURE=true
